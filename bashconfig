eval "$(starship init bash)"
eval "$(direnv hook bash)"

export EDITOR=hx
export PATH=$PATH:$HOME/.cargo/bin
export PATH=$PATH:$HOME/go/bin
export PATH=$PATH:$HOME/bin
export PATH=$PATH:$HOME/.deno/bin
export PATH=$PATH:$HOME/.local/bin

export HSA_OVERRIDE_GFX_VERSION=10.3.0
alias yuzu="appimage-run $HOME/Applications/yuzu.AppImage"

export FLYCTL_INSTALL="/home/jay/.fly"
export PATH="$FLYCTL_INSTALL/bin:$PATH"

# Google API credentials (stored in separate files to avoid committing secrets)
if [ -f "$HOME/.config/google-access-token" ]; then
  export GOOGLE_ACCESS_TOKEN=$(cat "$HOME/.config/google-access-token")
fi
if [ -f "$HOME/.config/google-client-id" ]; then
  export GOOGLE_CLIENT_ID=$(cat "$HOME/.config/google-client-id")
fi
if [ -f "$HOME/.config/google-client-secret" ]; then
  export GOOGLE_CLIENT_SECRET=$(cat "$HOME/.config/google-client-secret")
fi

# source $HOME/dotfiles/export-esp.sh
